# ===================================================================
# TECHTRAFO API - Dockerfile de desarrollo
# ===================================================================
# Usa Node 22 alpine. Hot reload via ts-node-dev y volumen montado.
# Para produccion: Dockerfile separado con multi-stage build (FASE futura).
# ===================================================================
FROM node:22-alpine

WORKDIR /app

# Dependencias del sistema requeridas por Prisma en alpine
RUN apk add --no-cache openssl libc6-compat

# Instalar deps primero (capa cacheable)
COPY package.json package-lock.json* ./
RUN npm install

# Copiar el resto del codigo (en dev se sobrescribe por el volumen del compose,
# pero esta copia es util para correr la imagen sin volumen si hace falta)
COPY . .

# Generar Prisma Client con el schema actual (idempotente).
# Esto debe ir DESPUES del COPY del schema.prisma; el postinstall hook
# corre antes y no tendria los modelos disponibles.
RUN npx prisma generate

EXPOSE 3000

CMD ["npm", "run", "dev"]
