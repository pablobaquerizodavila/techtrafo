# ===================================================================
# TECHTRAFO API - Variables de entorno (plantilla)
# ===================================================================
# En produccion via docker-compose, estas vars se inyectan desde el
# .env del stack (infrastructure/docker/.env). Este archivo solo
# documenta lo que el backend espera ver en process.env.
# ===================================================================

NODE_ENV=development
PORT=3000

# Construida por el compose: postgresql://<user>:<pass>@techtrafo-postgres:5432/<db>
DATABASE_URL=postgresql://techtrafo_admin:CAMBIAR@localhost:5432/techtrafo?schema=public

# Para 3.3 (auth) - JWT secret. Generar con: openssl rand -base64 48
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
