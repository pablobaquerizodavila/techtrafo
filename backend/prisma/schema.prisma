generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["comercial", "core", "inventario", "posventa", "produccion"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cliente_contactos {
  id                                                   BigInt         @id @default(autoincrement())
  cliente_id                                           BigInt
  nombres                                              String         @db.VarChar(100)
  apellidos                                            String?        @db.VarChar(100)
  cargo                                                String?        @db.VarChar(100)
  telefono                                             String?        @db.VarChar(20)
  celular                                              String?        @db.VarChar(20)
  email                                                String?        @db.VarChar(255)
  es_principal                                         Boolean?       @default(false)
  recibe_notificaciones                                Boolean?       @default(true)
  notas                                                String?
  estado                                               String?        @default("activo") @db.VarChar(20)
  creado_por                                           String?        @db.Uuid
  actualizado_por                                      String?        @db.Uuid
  created_at                                           DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at                                           DateTime?      @default(now()) @db.Timestamptz(6)
  usuarios_cliente_contactos_actualizado_porTousuarios usuarios?      @relation("cliente_contactos_actualizado_porTousuarios", fields: [actualizado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientes                                             clientes       @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios_cliente_contactos_creado_porTousuarios      usuarios?      @relation("cliente_contactos_creado_porTousuarios", fields: [creado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cotizaciones                                         cotizaciones[]
  expedientes                                          expedientes[]
  reclamos                                             reclamos[]

  @@index([cliente_id], map: "idx_contactos_cliente")
  @@index([email], map: "idx_contactos_email")
  @@schema("comercial")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model clientes {
  id                                          BigInt              @id @default(autoincrement())
  tipo_persona                                String              @db.VarChar(20)
  razon_social                                String              @db.VarChar(200)
  nombre_comercial                            String?             @db.VarChar(200)
  ruc_cedula                                  String              @unique @db.VarChar(13)
  direccion_fiscal                            String?
  ciudad                                      String?             @db.VarChar(80)
  provincia                                   String?             @db.VarChar(80)
  pais                                        String?             @default("Ecuador") @db.VarChar(80)
  telefono                                    String?             @db.VarChar(20)
  email                                       String?             @db.VarChar(255)
  sitio_web                                   String?             @db.VarChar(255)
  segmento                                    String?             @db.VarChar(30)
  sector                                      String?             @db.VarChar(20)
  credito_habilitado                          Boolean?            @default(false)
  limite_credito                              Decimal?            @default(0) @db.Decimal(14, 2)
  plazo_credito_dias                          Int?                @default(0)
  estado                                      String?             @default("activo") @db.VarChar(20)
  notas                                       String?
  creado_por                                  String?             @db.Uuid
  actualizado_por                             String?             @db.Uuid
  created_at                                  DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at                                  DateTime?           @default(now()) @db.Timestamptz(6)
  cliente_contactos                           cliente_contactos[]
  usuarios_clientes_actualizado_porTousuarios usuarios?           @relation("clientes_actualizado_porTousuarios", fields: [actualizado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios_clientes_creado_porTousuarios      usuarios?           @relation("clientes_creado_porTousuarios", fields: [creado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contratos                                   contratos[]
  cotizaciones                                cotizaciones[]
  expedientes                                 expedientes[]
  garantias                                   garantias[]

  @@index([estado], map: "idx_clientes_estado")
  @@index([razon_social], map: "idx_clientes_razon")
  @@index([ruc_cedula], map: "idx_clientes_ruc")
  @@index([segmento], map: "idx_clientes_segmento")
  @@schema("comercial")
}

