model auditoria {
  id             BigInt    @id @default(autoincrement())
  usuario_id     String?   @db.Uuid
  modulo         String    @db.VarChar(50)
  accion         String    @db.VarChar(50)
  entidad        String?   @db.VarChar(100)
  entidad_id     String?   @db.VarChar(100)
  valor_anterior Json?
  valor_nuevo    Json?
  ip_origen      String?   @db.Inet
  user_agent     String?
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  usuarios       usuarios? @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_auditoria_fecha")
  @@index([modulo, created_at], map: "idx_auditoria_modulo_fecha")
  @@index([usuario_id], map: "idx_auditoria_usuario")
  @@schema("core")
}

