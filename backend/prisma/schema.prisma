model cotizacion_revisiones {
  id            BigInt       @id @default(autoincrement())
  cotizacion_id BigInt
  revision      Int
  snapshot      Json
  motivo        String?
  creado_por    String?      @db.Uuid
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  cotizaciones  cotizaciones @relation(fields: [cotizacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios      usuarios?    @relation(fields: [creado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([cotizacion_id, revision])
  @@index([cotizacion_id], map: "idx_cot_revisiones_cotizacion")
  @@schema("comercial")
}

