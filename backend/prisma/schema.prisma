  updated_at                 DateTime?    @default(now()) @db.Timestamptz(6)
  cotizaciones               cotizaciones @relation(fields: [cotizacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  items                      items?       @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cotizacion_id], map: "idx_cot_lineas_cotizacion")
