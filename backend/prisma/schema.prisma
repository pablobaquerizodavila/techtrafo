  @@index([cotizacion_id], map: "idx_contratos_cotizacion")
  @@index([estado], map: "idx_contratos_estado")
  @@index([fecha_firma(sort: Desc)], map: "idx_contratos_fecha_firma")
  @@schema("comercial")
}

model contrato_plantillas {
  id              BigInt                     @id @default(autoincrement())
  codigo          String                     @unique @db.VarChar(30)
  nombre          String                     @db.VarChar(200)
  descripcion     String?
  tipo_servicio   String                     @default("otro") @db.VarChar(20)
  clausulas       String?
  plan_pago_tipo  String                     @default("anticipo_y_saldo") @db.VarChar(30)
  activo          Boolean                    @default(true)
  creado_por      String?                    @db.Uuid
  actualizado_por String?                    @db.Uuid
  created_at      DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                   @default(now()) @db.Timestamptz(6)
  pagos           contrato_plantilla_pagos[]

  @@index([tipo_servicio, activo], map: "idx_contrato_plantillas_tipo")
  @@schema("comercial")
}

model contrato_plantilla_pagos {
  id                  BigInt              @id @default(autoincrement())
  plantilla_id        BigInt
  numero              Int
  tipo                String              @default("anticipo") @db.VarChar(20)
  descripcion         String?
  condicion_disparo   String?             @db.VarChar(30)
  monto_porcentaje    Decimal?            @db.Decimal(5, 2)
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  contrato_plantillas contrato_plantillas @relation(fields: [plantilla_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([plantilla_id, numero], map: "idx_contrato_plantilla_pagos_plantilla")
  @@schema("comercial")
}

