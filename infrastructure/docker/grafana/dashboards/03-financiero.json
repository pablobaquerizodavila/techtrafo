        "rawSql": "SELECT c.codigo AS contrato, cl.razon_social AS cliente, p.numero AS cuota, p.tipo, p.fecha_esperada AS vence, p.monto_estipulado::float AS estipulado, COALESCE(p.monto_pagado,0)::float AS pagado, (p.monto_estipulado - COALESCE(p.monto_pagado,0))::float AS saldo, p.estado FROM comercial.contrato_pagos p JOIN comercial.contratos c ON c.id = p.contrato_id JOIN comercial.clientes cl ON cl.id = c.cliente_id WHERE p.estado IN ('pendiente','parcial') ORDER BY p.fecha_esperada ASC NULLS LAST LIMIT 30",
