# ===================================================================
# TECHTRAFO - Plantilla de variables de entorno
# ===================================================================
# Copiar este archivo a .env y reemplazar los placeholders.
# IMPORTANTE: el archivo .env NO se sube a Git (ya esta en .gitignore)
#
# Generar passwords seguras con:
#   openssl rand -base64 24
# ===================================================================

# --- PostgreSQL ---
POSTGRES_DB=techtrafo
POSTGRES_USER=techtrafo_admin
POSTGRES_PASSWORD=CAMBIAR_CON_PASSWORD_SEGURA

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_CON_PASSWORD_SEGURA

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CAMBIAR_CON_PASSWORD_SEGURA

# --- Entorno general ---
TZ=America/Guayaquil
