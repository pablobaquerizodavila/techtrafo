# ===================================================================
# TECHTRAFO Web - Variables de entorno
# ===================================================================
# Por convencion de Next.js, las vars que el browser puede leer
# llevan prefijo NEXT_PUBLIC_. Las demas solo viven en el server.
#
# En produccion via docker-compose, estas vars se inyectan desde el
# .env del stack (infrastructure/docker/.env).
# ===================================================================

# URL base del API (cliente y server). En dev apunta al backend en el host.
# En FASE 3.7 cambiar a https://api.techtrafo.com
NEXT_PUBLIC_API_URL=http://192.168.0.23:3000
